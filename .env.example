# Copy this file to backend/.env and fill in your keys.
# Keys set here are loaded at startup as the default provider credentials.
# Keys entered in the in-app Settings panel take priority for that session.

# Pick one (or both — the app lets you switch providers in Settings):
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default provider when the app starts ("claude" or "openai"):
LLM_PROVIDER=claude
